# ─── Twilio ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# ─── ElevenLabs ───────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Voice ID to use for the agent (default: Rachel — warm, calm)
# Browse voices at: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Leave EMPTY on first run — the app will auto-create the agent
# and print the generated Agent ID for you to paste here.
ELEVENLABS_AGENT_ID=

# ─── Server ───────────────────────────────────────────────
# Public HTTPS URL where Twilio reaches this service.
#   Local dev:  use ngrok / Cloudflare Tunnel (https://...ngrok-free.app)
#   Production: https://<this-service>.up.railway.app
# The TwiML answer endpoint and the WebSocket Media Stream URL are derived
# from this. On startup the app auto-configures the Twilio number's voice_url
# to {PUBLIC_BASE_URL}/twiml/answer — no manual Twilio console step required.
PUBLIC_BASE_URL=https://your-public-url.example.com

# ─── Bloom portal (post-call ingestion target) ─────────────
# Where this service POSTs call summaries + severity verdicts after each call.
#   Local dev:  http://localhost:8001
#   Production: https://<backend>.up.railway.app
PORTAL_BASE_URL=http://localhost:8001

# ─── OpenAI (optional) ─────────────────────────────────────
# Improves post-call severity classification. Without it, a rule-based scan
# handles obvious red flags.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
